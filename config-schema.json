{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "number"
    },
    "groups": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/__schema0"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "colour": {
            "type": "string"
          },
          "matcher": {
            "type": "string"
          }
        },
        "required": ["key", "name", "colour"],
        "additionalProperties": false
      }
    }
  },
  "required": ["version", "groups"],
  "additionalProperties": false,
  "$defs": {
    "__schema0": {
      "type": "object",
      "properties": {
        "key": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "icon": {
          "type": "string"
        },
        "matcher": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/__schema0"
          }
        },
        "expandedByDefault": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        }
      },
      "required": ["key", "name"],
      "additionalProperties": false
    }
  }
}
