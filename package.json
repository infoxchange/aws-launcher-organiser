{
  "name": "aws-launcher-organiser",
  "displayName": "AWS Launcher Organiser",
  "version": "0.0.0-version-set-when-releasing",
  "description": "Browser extension to organise AWS accounts on the launcher page",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "build:firefox": "wxt build --browser firefox",
    "build:chrome": "wxt build --browser chrome",
    "build:all": "wxt build --browser firefox && wxt build --browser chrome",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip --browser firefox",
    "zip:chrome": "wxt zip --browser chrome",
    "lint": "biome check --verbose --error-on-warnings && tsc --noEmit",
    "lint:fix": "biome check --write && tsc --noEmit",
    "format": "biome format --write",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:integration:setup": "tsx scripts/setup-integration-tests.ts",
    "test:integration": "npm run build:chrome && vitest --config vitest.integration.config.ts --run tests/integration/",
    "test:integration:watch": "npm run build:chrome && vitest --config vitest.integration.config.ts tests/integration/",
    "test:integration:clear-cookies": "node -e \"import('./src/utils/test-cookies.ts').then(m => m.clearCookies()) && console.log('✓ Cookies cleared')\"",
    "generate-schema": "tsx scripts/generate-schema.ts",
    "lint-staged": "lint-staged"
  },
  "dependencies": {
    "playwright": "^1.59.1",
    "primeicons": "^7.0.0",
    "primereact": "^10.9.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/chrome": "^0.1.38",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "@vitest/ui": "^4.1.0",
    "happy-dom": "^20.8.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "semantic-release": "^25.0.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "wxt": "^0.20.19"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "biome check --write"
    ],
    "*.json": [
      "biome format --write"
    ],
    "*": [
      "npm run generate-schema -- && git add config-schema.json || true"
    ]
  },
  "private": true
}
