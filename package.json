{
  "name": "aws-launcher-organiser",
  "displayName": "AWS Launcher Organiser",
  "version": "0.1.0",
  "description": "Browser extension to organise AWS accounts on the launcher page",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "build:firefox": "wxt build --browser firefox",
    "build:chrome": "wxt build --browser chrome",
    "build:all": "wxt build --browser firefox && wxt build --browser chrome",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip --browser firefox",
    "zip:chrome": "wxt zip --browser chrome",
    "lint": "biome check --verbose && tsc --noEmit",
    "lint:fix": "biome check --write && tsc --noEmit",
    "format": "biome format --write",
    "generate-schema": "tsx scripts/generate-schema.ts",
    "lint-staged": "lint-staged"
  },
  "dependencies": {
    "primeicons": "^7.0.0",
    "primereact": "^10.9.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/chrome": "^0.1.38",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "wxt": "^0.20.19"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "biome check --write"
    ],
    "*.{json,md}": [
      "biome format --write"
    ],
    "*": [
      "npm run generate-schema -- && git add config-schema.json || true"
    ]
  },
  "private": true
}
